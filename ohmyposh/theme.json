{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "bg": "#0A0E14",
    "fg": "#B3B1AD",
    "accent": "#39BAE6",
    "green": "#AAD94C",
    "yellow": "#FFB454",
    "orange": "#FF8F40",
    "red": "#F07178",
    "magenta": "#D2A6FF",
    "gray": "#626A73"
  },
  "console_title_template": "{{ .Shell }}@{{ .UserName }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "p:magenta",
          "template": "{{ .UserName }}",
          "properties": {
            "cache_duration": "none"
          }
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:gray",
          "template": ":"
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:accent",
          "template": "{{ .Path }}",
          "properties": {
            "cache_duration": "none",
            "style": "full",
            "folder_separator_icon": ":"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:green",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}   {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }}",
          "properties": {
            "branch_icon": " ",
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_worktree_count": true
          },
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:orange{{ end }}",
            "{{ if gt .Ahead 0 }}p:green{{ end }}",
            "{{ if gt .Behind 0 }}p:red{{ end }}"
          ]
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:red",
          "template": "{{ if gt .Code 0 }} : {{ reason .Code }}{{ end }}",
          "properties": {
            "cache_duration": "none"
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "python",
          "style": "plain",
          "foreground": "p:yellow",
          "template": "{{ if .Venv }} {{ .Venv }}@{{ .Full }}{{ end }}",
          "properties": {
            "cache_duration": "none",
            "display_mode": "environment",
            "fetch_version": true,
            "fetch_virtual_env": true,
            "folder_name_fallback": false,
            "home_enabled": true
          }
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:gray",
          "template": " {{ .FormattedMs }}",
          "properties": {
            "always_enabled": true,
            "cache_duration": "none",
            "style": "austin",
            "threshold": 500
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:gray",
          "template": " 󰥔 {{ .CurrentDate | date .Format }}",
          "properties": {
            "cache_duration": "none"
          }
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
